{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": [
    "electron.vite.config.*",
    "vite.config.*",
    "electron/main/**/*",
    "electron/preload/**/*",
    "electron/shared/**/*",
    "src/types/**/*",
    "packages/shared-types/**/*",
    "packages/core/**/*",
    "packages/node-runtime/**/*",
    "packages/config/**/*",
    "packages/parser/**/*",
    "packages/server/**/*",
    "packages/tools/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "types": ["electron-vite/node"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@electron/*": ["electron/*"],
      "@openchatlab/*": ["packages/*"]
    }
  }
}
